# Environment variables for Local Development
# Copy this to .env and customize

# Database
DATABASE_URL=postgresql+psycopg2://zoneweaver_db_user:FJdjpGjfLn4Fa9VfM2FCRXSfX13jg2rk@dpg-d7bscjggjchc73fhscf0-a.oregon-postgres.render.com/zoneweaver_db_5isc

# Security
SECRET_KEY=your-change-me-secret-key-minimum-32-characters-long-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# H3 Configuration
H3_DEFAULT_RESOLUTION=13
H3_MIN_RESOLUTION=0
H3_MAX_RESOLUTION=15

# Account Configuration
MAX_ZONES_PER_USER=3

# API
API_TITLE=Zone Weaver API
API_VERSION=1.0.0
API_DESCRIPTION=User-Defined Zone Message Distribution Platform

# Guest access QR — SPA origin serving /access?zid=… (no trailing slash)
GUEST_ACCESS_APP_BASE_URL=
# Deprecated alias used only when GUEST_ACCESS_APP_BASE_URL is empty
PUBLIC_WEB_APP_URL=
# Anonymous POST /api/access/permission — max requests per client IP per rolling minute
GUEST_ACCESS_PERMISSION_MAX_PER_MINUTE=60

# Registration code HMAC secret (falls back to SECRET_KEY if blank)
REGISTRATION_CODE_HMAC_SECRET=
REGISTRATION_CODE_EXPIRE_HOURS=24

# Support contact info embedded in REG-CODE issuance emails / API response
SUPPORT_CONTACT_NAME=Hex Zone Support
SUPPORT_CONTACT_EMAIL=support@zoneweaver.com
SUPPORT_CONTACT_PHONE=+1 (555) 010-0123
SUPPORT_CONTACT_WEBSITE=https://zoneweaver.com

# SMTP (Resend.com example). Leave SMTP_HOST blank to log emails instead of sending.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=noreply@zoneweaver.com
SMTP_USE_SSL=true
SMTP_TIMEOUT_SECONDS=15
